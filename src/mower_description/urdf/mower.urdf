<?xml version="1.0"?>
<robot name="mower" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- 颜色定义 -->
  <material name="graphite">
    <color rgba="0.16 0.18 0.20 1.0"/>
  </material>
  <material name="snow_white">
    <color rgba="0.92 0.93 0.95 1.0"/>
  </material>
  <material name="accent_orange">
    <color rgba="0.95 0.44 0.08 1.0"/>
  </material>
  <material name="signal_yellow">
    <color rgba="0.95 0.83 0.14 1.0"/>
  </material>
  <material name="metal_silver">
    <color rgba="0.72 0.74 0.78 1.0"/>
  </material>
  <material name="wheel_rubber">
    <color rgba="0.04 0.04 0.04 1.0"/>
  </material>
  <material name="sensor_black">
    <color rgba="0.08 0.09 0.11 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.0 0.0 0.0 1.0"/>
  </material>
  <material name="silver">
    <color rgba="0.75 0.75 0.75 1.0"/>
  </material>

  <!-- 底盘（多层涂装） -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.5665 0.37 0.12"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0.06"/>
      <material name="graphite">
        <color rgba="0.16 0.18 0.20 1.0"/>
      </material>
    </visual>
    <visual>
      <geometry>
        <box size="0.48 0.29 0.03"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0.135"/>
      <material name="snow_white">
        <color rgba="0.92 0.93 0.95 1.0"/>
      </material>
    </visual>
    <visual>
      <geometry>
        <box size="0.54 0.015 0.025"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0.142 0.092"/>
      <material name="accent_orange">
        <color rgba="0.95 0.44 0.08 1.0"/>
      </material>
    </visual>
    <visual>
      <geometry>
        <box size="0.48 0.015 0.025"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 -0.142 0.092"/>
      <material name="accent_orange">
        <color rgba="0.95 0.44 0.08 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.5665 0.37 0.15"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0.075"/>
    </collision>
    <inertial>
      <mass value="10.0"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
  </link>

  <!-- 驱动轮（左后） -->
  <link name="left_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.11" length="0.05"/>
      </geometry>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
      <material name="wheel_rubber">
        <color rgba="0.04 0.04 0.04 1.0"/>
      </material>
    </visual>
    <visual>
      <geometry>
        <cylinder radius="0.060" length="0.052"/>
      </geometry>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
      <material name="metal_silver">
        <color rgba="0.72 0.74 0.78 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.11" length="0.05"/>
      </geometry>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <!-- 驱动轮（右后） -->
  <link name="right_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.11" length="0.05"/>
      </geometry>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
      <material name="wheel_rubber">
        <color rgba="0.04 0.04 0.04 1.0"/>
      </material>
    </visual>
    <visual>
      <geometry>
        <cylinder radius="0.060" length="0.052"/>
      </geometry>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
      <material name="metal_silver">
        <color rgba="0.72 0.74 0.78 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.11" length="0.05"/>
      </geometry>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <!-- 支撑轮（左前） -->
  <link name="front_left_caster">
    <visual>
      <geometry>
        <cylinder radius="0.045" length="0.03"/>
      </geometry>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
      <material name="wheel_rubber">
        <color rgba="0.04 0.04 0.04 1.0"/>
      </material>
    </visual>
    <visual>
      <geometry>
        <cylinder radius="0.028" length="0.032"/>
      </geometry>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
      <material name="metal_silver">
        <color rgba="0.72 0.74 0.78 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.045" length="0.03"/>
      </geometry>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.8"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <!-- 支撑轮（右前） -->
  <link name="front_right_caster">
    <visual>
      <geometry>
        <cylinder radius="0.045" length="0.03"/>
      </geometry>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
      <material name="wheel_rubber">
        <color rgba="0.04 0.04 0.04 1.0"/>
      </material>
    </visual>
    <visual>
      <geometry>
        <cylinder radius="0.028" length="0.032"/>
      </geometry>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
      <material name="metal_silver">
        <color rgba="0.72 0.74 0.78 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.045" length="0.03"/>
      </geometry>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.8"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <!-- 雷达支架（中心短圆柱） -->
  <link name="lidar_mast_link">
    <visual>
      <geometry>
        <cylinder radius="0.02" length="0.04"/>
      </geometry>
      <material name="sensor_black">
        <color rgba="0.08 0.09 0.11 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.02" length="0.04"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.0002"/>
    </inertial>
  </link>

  <!-- 激光雷达 link -->
  <link name="laser_link">
    <visual>
      <geometry>
        <box size="0.1 0.1 0.05"/>
      </geometry>
      <material name="sensor_black">
        <color rgba="0.08 0.09 0.11 1.0"/>
      </material>
    </visual>
    <visual>
      <geometry>
        <box size="0.102 0.102 0.012"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0.018"/>
      <material name="accent_orange">
        <color rgba="0.95 0.44 0.08 1.0"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <!-- 深度相机 link -->
  <link name="camera_link">
    <visual>
      <geometry>
        <box size="0.08 0.03 0.03"/>
      </geometry>
      <material name="sensor_black">
        <color rgba="0.08 0.09 0.11 1.0"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <!-- 深度相机光学坐标系（REP-103/REP-105）:
       optical frame: x right, y down, z forward.
       这样点云/深度数据在 RViz 里方向与图像一致。 -->
  <link name="camera_optical_frame"/>

  <!-- 超声波传感器 link（车体前方） -->
  <link name="ultrasonic_link">
    <visual>
      <geometry>
        <box size="0.04 0.02 0.02"/>
      </geometry>
      <material name="metal_silver">
        <color rgba="0.72 0.74 0.78 1.0"/>
      </material>
    </visual>
    <visual>
      <geometry>
        <box size="0.005 0.02 0.02"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0.018 0 0"/>
      <material name="sensor_black">
        <color rgba="0.08 0.09 0.11 1.0"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.00005" ixy="0" ixz="0" iyy="0.00005" iyz="0" izz="0.00005"/>
    </inertial>
  </link>

  <!-- IMU link（车体内部） -->
  <link name="imu_link">
    <visual>
      <geometry>
        <box size="0.02 0.02 0.01"/>
      </geometry>
      <material name="sensor_black">
        <color rgba="0.08 0.09 0.11 1.0"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.02"/>
      <inertia ixx="0.00002" ixy="0" ixz="0" iyy="0.00002" iyz="0" izz="0.00002"/>
    </inertial>
  </link>

  <!-- 碰撞传感器 link（放在小车前方） -->
  <link name="bumper_link">
    <visual>
      <geometry>
        <box size="0.1 0.3 0.05"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0.25 0 0.025"/>
      <material name="signal_yellow">
        <color rgba="0.95 0.83 0.14 1.0"/>
      </material>
    </visual>
    <visual>
      <geometry>
        <box size="0.105 0.28 0.012"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0.275 0 0.04"/>
      <material name="sensor_black">
        <color rgba="0.08 0.09 0.11 1.0"/>
      </material>
    </visual>
    <collision name="bumper_link_collision">
      <geometry>
        <box size="0.1 0.3 0.05"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0.25 0 0.025"/>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <!-- 切割电机主体（缩小） -->
  <link name="cutting_motor_link">
    <visual>
      <geometry>
        <cylinder radius="0.03" length="0.03"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.03" length="0.03"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <!-- 刀片1 -->
  <link name="blade1_link">
    <visual>
      <geometry>
        <box size="0.18 0.01 0.005"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <material name="silver">
        <color rgba="0.7 0.7 0.7 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.18 0.01 0.005"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <!-- 刀片2 -->
  <link name="blade2_link">
    <visual>
      <geometry>
        <box size="0.18 0.01 0.005"/>
      </geometry>
      <origin rpy="0 0 1.047" xyz="0 0 0"/>
      <material name="silver">
        <color rgba="0.7 0.7 0.7 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.18 0.01 0.005"/>
      </geometry>
      <origin rpy="0 0 1.047" xyz="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <!-- 刀片3 -->
  <link name="blade3_link">
    <visual>
      <geometry>
        <box size="0.18 0.01 0.005"/>
      </geometry>
      <origin rpy="0 0 2.094" xyz="0 0 0"/>
      <material name="silver">
        <color rgba="0.7 0.7 0.7 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.18 0.01 0.005"/>
      </geometry>
      <origin rpy="0 0 2.094" xyz="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>


  <!-- 关节：左驱动轮 -->
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <!-- REP-103: +Y is left. Place left wheel on +Y. -->
    <!-- Keep chassis clearance above ground:
         base_link is the chassis bottom plane, so wheel_center_z = wheel_radius - clearance -->
    <origin rpy="0 0 0" xyz="-0.12 0.16 0.03"/>
    <axis xyz="0 1 0"/>
    <limit effort="100" velocity="10"/>
    <dynamics damping="1.0" friction="1.0"/>
  </joint>

  <!-- 关节：右驱动轮 -->
  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <!-- REP-103: +Y is left. Place right wheel on -Y. -->
    <!-- Keep chassis clearance above ground -->
    <origin rpy="0 0 0" xyz="-0.12 -0.16 0.03"/>
    <axis xyz="0 1 0"/>
    <limit effort="100" velocity="10"/>
    <dynamics damping="1.0" friction="1.0"/>
  </joint>

  <!-- 关节：左前支撑轮（可滚动） -->
  <joint name="front_left_caster_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_left_caster"/>
    <!-- Push outward so it doesn't intersect the chassis, and set z to caster radius. -->
    <!-- REP-103: +Y is left. Place front-left caster on +Y. -->
    <!-- caster_center_z = caster_radius - clearance -->
    <origin rpy="0 0 0" xyz="0.180 0.0925 -0.035"/>
    <axis xyz="0 1 0"/>
    <limit effort="20" velocity="20"/>
    <dynamics damping="0.2" friction="0.2"/>
  </joint>

  <!-- 关节：右前支撑轮（可滚动） -->
  <joint name="front_right_caster_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_right_caster"/>
    <!-- REP-103: +Y is left. Place front-right caster on -Y. -->
    <origin rpy="0 0 0" xyz="0.180 -0.0925 -0.035"/>
    <axis xyz="0 1 0"/>
    <limit effort="20" velocity="20"/>
    <dynamics damping="0.2" friction="0.2"/>
  </joint>

  <!-- 关节：雷达支架（位于车体中心、上表面） -->
  <joint name="lidar_mast_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_mast_link"/>
    <!-- base_link 的底盘顶面约在 z=0.15，支架长度 0.04 -->
    <origin rpy="0 0 0" xyz="0.0 0.0 0.17"/>
  </joint>

  <!-- 关节：激光雷达 -->
  <joint name="laser_joint" type="fixed">
    <parent link="lidar_mast_link"/>
    <child link="laser_link"/>
    <!-- 支架顶面到雷达中心：0.02(支架半高) + 0.025(雷达半高) -->
    <origin rpy="0 0 0" xyz="0 0 0.045"/>
  </joint>

  <!-- 关节：深度相机 -->
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <!-- 放在车体上表面前方 -->
    <origin rpy="0 0 0" xyz="0.22 0 0.165"/>
  </joint>

  <!-- camera_link -> camera_optical_frame 的固定变换 -->
  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_optical_frame"/>
    <!-- Convert from a typical body frame (x forward, y left, z up) to optical -->
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
  </joint>

  <!-- 关节：超声波传感器（前方） -->
  <joint name="ultrasonic_joint" type="fixed">
    <parent link="base_link"/>
    <child link="ultrasonic_link"/>
    <origin rpy="0 0 0" xyz="0.27 0 0.08"/>
  </joint>

  <!-- 关节：IMU（车体内部） -->
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin rpy="0 0 0" xyz="0 0 0.075"/>
  </joint>

  <!-- 关节：碰撞传感器 -->
  <joint name="bumper_joint" type="fixed">
    <parent link="base_link"/>
    <child link="bumper_link"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
  </joint>

  <!-- 关节：刀片1（固定到电机） -->
  <joint name="blade1_joint" type="fixed">
    <parent link="cutting_motor_link"/>
    <child link="blade1_link"/>
    <origin rpy="0 0 0" xyz="0 0 -0.016"/>
  </joint>

  <!-- 关节：刀片2（固定到电机） -->
  <joint name="blade2_joint" type="fixed">
    <parent link="cutting_motor_link"/>
    <child link="blade2_link"/>
    <origin rpy="0 0 0" xyz="0 0 -0.016"/>
  </joint>

  <!-- 关节：刀片3（固定到电机） -->
  <joint name="blade3_joint" type="fixed">
    <parent link="cutting_motor_link"/>
    <child link="blade3_link"/>
    <origin rpy="0 0 0" xyz="0 0 -0.016"/>
  </joint>

  <!-- 关节：电机旋转 -->
  <joint name="blade_joint" type="continuous">
    <parent link="base_link"/>
    <child link="cutting_motor_link"/>
    <origin rpy="0 0 0" xyz="0 0 -0.01"/>
    <axis xyz="0 0 1"/>
    <limit effort="50" velocity="80"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <!-- Gazebo 配置：插件和传感器 -->
  <gazebo>
    <!-- 差速驱动插件（ROS2 版本） -->
    <plugin name="gazebo_ros_diff_drive" filename="libgazebo_ros_diff_drive.so">
      <ros>
        <namespace>/mower</namespace>
        <remapping>cmd_vel:=/cmd_vel</remapping>
        <remapping>odom:=/odom</remapping>
        <!-- TF topics are just normal topics in ROS2; with a namespace they'd become /mower/tf.
             Remap them back to the global /tf and /tf_static so Nav2/RViz can see odom->base_link. -->
        <remapping>tf:=/tf</remapping>
        <remapping>tf_static:=/tf_static</remapping>
      </ros>
      <update_rate>30</update_rate>
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.4</wheel_separation>
      <wheel_diameter>0.2</wheel_diameter>
      <max_wheel_torque>10</max_wheel_torque>
      <max_wheel_acceleration>1.0</max_wheel_acceleration>
      <!-- Use absolute topics to avoid namespace/remap ambiguity -->
      <command_topic>/cmd_vel</command_topic>
      <odometry_topic>/odom</odometry_topic>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_link</robot_base_frame>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <!-- Wheel link TF should come from robot_state_publisher (URDF). If Gazebo also publishes
           wheel TF, it can create duplicate/conflicting transforms and trigger TF_OLD_DATA. -->
      <publish_wheel_tf>false</publish_wheel_tf>
    </plugin>

    <!-- 发布轮子 joint_states（RViz 里看关节/TF 更直观） -->
    <plugin name="gazebo_ros_joint_state_publisher" filename="libgazebo_ros_joint_state_publisher.so">
      <ros>
        <!-- 发布到全局主题，确保robot_state_publisher能接收到 -->
        <remapping>~/out:=/joint_states</remapping>
      </ros>
      <update_rate>30</update_rate>
      <joint_name>left_wheel_joint</joint_name>
      <joint_name>right_wheel_joint</joint_name>
      <joint_name>front_left_caster_joint</joint_name>
      <joint_name>front_right_caster_joint</joint_name>
      <joint_name>blade_joint</joint_name>
    </plugin>
  </gazebo>

  <!-- 刀片关节轨迹控制器（ROS2 Humble 可用插件） -->
  <gazebo>
    <plugin name="blade_trajectory_controller" filename="libgazebo_ros_joint_pose_trajectory.so">
      <ros>
        <namespace>/mower/blade</namespace>
      </ros>
      <update_rate>100.0</update_rate>
      <joint_name>blade_joint</joint_name>
    </plugin>
  </gazebo>

  <!-- 激光雷达传感器配置（ROS2 插件） -->
  <gazebo reference="laser_link">
    <sensor type="ray" name="laser">
      <pose>0 0 0 0 0 0</pose>
      <visualize>false</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.2</min>
          <max>10.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>
      <plugin name="gazebo_ros_ray_sensor" filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <!-- gazebo_ros_ray_sensor publishes on ~/out; remap it to a standard topic -->
          <remapping>~/out:=/scan</remapping>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>laser_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <!-- 超声波传感器配置（用 ray 模拟，单束） -->
  <gazebo reference="ultrasonic_link">
    <sensor type="ray" name="ultrasonic">
      <pose>0 0 0 0 0 0</pose>
      <visualize>false</visualize>
      <update_rate>20</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>1</samples>
            <resolution>1</resolution>
            <min_angle>0</min_angle>
            <max_angle>0</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.02</min>
          <max>4.0</max>
          <resolution>0.01</resolution>
        </range>
      </ray>
      <!-- 注意：该插件输出 LaserScan；如果你需要 sensor_msgs/Range，可在 ROS 里做一次转换节点 -->
      <plugin name="gazebo_ros_ultrasonic" filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <namespace>/mower</namespace>
          <remapping>~/out:=ultrasonic/scan</remapping>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>ultrasonic_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <!-- 深度相机传感器配置（ROS2 插件） -->
  <gazebo reference="camera_link">
    <sensor type="depth" name="camera">
      <pose>0 0 0 0 0 0</pose>
      <update_rate>10</update_rate>
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>10.0</far>
        </clip>
      </camera>
      <plugin name="gazebo_ros_camera" filename="libgazebo_ros_camera.so">
        <ros>
          <namespace>/mower</namespace>
        </ros>
        <camera_name>camera</camera_name>
        <!-- Use optical frame so point cloud axes match RViz expectation -->
        <frame_name>camera_optical_frame</frame_name>
        <image_topic_name>rgb/image_raw</image_topic_name>
        <depth_topic_name>depth/image_raw</depth_topic_name>
        <point_cloud_topic_name>depth/points</point_cloud_topic_name>
      </plugin>
    </sensor>
  </gazebo>

  <!-- IMU 传感器配置（ROS2 插件） -->
  <gazebo reference="imu_link">
    <sensor type="imu" name="imu">
      <pose>0 0 0 0 0 0</pose>
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <imu>
        <angular_velocity/>
        <linear_acceleration/>
      </imu>
      <plugin name="gazebo_ros_imu" filename="libgazebo_ros_imu_sensor.so">
        <ros>
          <namespace>/mower</namespace>
          <remapping>~/out:=imu/data</remapping>
        </ros>
      </plugin>
    </sensor>
  </gazebo>

  <!-- 碰撞传感器配置（接触传感器，ROS2 插件） -->
  <gazebo reference="bumper_link">
    <sensor type="contact" name="bumper_contact">
      <pose>0 0 0 0 0 0</pose>
      <update_rate>10</update_rate>
      <contact>
        <collision>bumper_link_collision</collision>
      </contact>
      <plugin name="gazebo_ros_contact_sensor" filename="libgazebo_ros_contact_sensor.so">
        <ros>
          <namespace>/mower</namespace>
        </ros>
        <contact_topic>bumper_contact</contact_topic>
      </plugin>
    </sensor>
  </gazebo>

  <!-- Gazebo 强制材质：避免 URDF 命名材质在 Gazebo 中退化为默认白色 -->
  <gazebo reference="base_link">
    <material>Gazebo/Grey</material>
    <ambient>0.16 0.18 0.20 1</ambient>
    <diffuse>0.16 0.18 0.20 1</diffuse>
    <specular>0.05 0.05 0.05 1</specular>
  </gazebo>
  <gazebo reference="lidar_mast_link">
    <material>Gazebo/Black</material>
    <ambient>0.08 0.09 0.11 1</ambient>
    <diffuse>0.08 0.09 0.11 1</diffuse>
    <specular>0.03 0.03 0.03 1</specular>
  </gazebo>
  <gazebo reference="laser_link">
    <material>Gazebo/Black</material>
    <ambient>0.08 0.09 0.11 1</ambient>
    <diffuse>0.08 0.09 0.11 1</diffuse>
    <specular>0.03 0.03 0.03 1</specular>
  </gazebo>
  <gazebo reference="camera_link">
    <material>Gazebo/Black</material>
    <ambient>0.08 0.09 0.11 1</ambient>
    <diffuse>0.08 0.09 0.11 1</diffuse>
    <specular>0.03 0.03 0.03 1</specular>
  </gazebo>
  <gazebo reference="ultrasonic_link">
    <material>Gazebo/Grey</material>
    <ambient>0.72 0.74 0.78 1</ambient>
    <diffuse>0.72 0.74 0.78 1</diffuse>
    <specular>0.10 0.10 0.10 1</specular>
  </gazebo>
  <gazebo reference="bumper_link">
    <material>Gazebo/Yellow</material>
    <ambient>0.95 0.83 0.14 1</ambient>
    <diffuse>0.95 0.83 0.14 1</diffuse>
    <specular>0.05 0.05 0.05 1</specular>
  </gazebo>

  <!-- 物理属性（可选） -->
  <gazebo reference="left_wheel">
    <material>Gazebo/Black</material>
    <ambient>0.04 0.04 0.04 1</ambient>
    <diffuse>0.04 0.04 0.04 1</diffuse>
    <specular>0.02 0.02 0.02 1</specular>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
  </gazebo>
  <gazebo reference="right_wheel">
    <material>Gazebo/Black</material>
    <ambient>0.04 0.04 0.04 1</ambient>
    <diffuse>0.04 0.04 0.04 1</diffuse>
    <specular>0.02 0.02 0.02 1</specular>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
  </gazebo>
  <gazebo reference="front_left_caster">
    <!-- Low friction so the front support wheels don't resist turning -->
    <material>Gazebo/Black</material>
    <ambient>0.04 0.04 0.04 1</ambient>
    <diffuse>0.04 0.04 0.04 1</diffuse>
    <specular>0.02 0.02 0.02 1</specular>
    <mu1>0.05</mu1>
    <mu2>0.05</mu2>
  </gazebo>
  <gazebo reference="front_right_caster">
    <!-- Low friction so the front support wheels don't resist turning -->
    <material>Gazebo/Black</material>
    <ambient>0.04 0.04 0.04 1</ambient>
    <diffuse>0.04 0.04 0.04 1</diffuse>
    <specular>0.02 0.02 0.02 1</specular>
    <mu1>0.05</mu1>
    <mu2>0.05</mu2>
  </gazebo>

</robot>
